# Token del bot de Telegram (lo da @BotFather)
BOT_TOKEN=

# Clave privada de TU wallet (la del dueño). Sin 0x o con 0x, ambos valen.
PRIVATE_KEY=

# Tu ID numérico de Telegram (escríbele a @userinfobot para saberlo).
# El bot ignora a CUALQUIERA que no esté en esta lista.
OWNER_ID=

# Opcional: otros IDs autorizados separados por coma. Cada uno usa SU propia
# wallet (la setean con /setwallet), nunca la tuya.
ALLOWED_USER_IDS=

# Clave para cifrar en disco las wallets de otros usuarios (frase larga aleatoria).
# Obligatoria solo si vas a autorizar a más gente.
WALLET_ENC_KEY=

# Opcional: sobreescribir RPCs por defecto
WSS_RPC=wss://bsc-rpc.publicnode.com
HTTP_RPC=https://bsc.rpc.blxrbdn.com
